<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NativeCal.Views.WeekViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NativeCal.Views"
    xmlns:helpers="using:NativeCal.Helpers"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <helpers:ColorHexToBrushConverter x:Key="ColorHexToBrushConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Row 0: Day column headers (time gutter + 7 day columns) -->
        <Grid Grid.Row="0" x:Name="DayHeadersGrid" Padding="0,8,0,4"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="GutterCol0" Width="64" MinWidth="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Col 0: empty gutter space -->
            <!-- Cols 1-7: populated in code-behind with day name + date number -->
        </Grid>

        <!-- Row 1: All-day events bar -->
        <Grid Grid.Row="1" x:Name="AllDayBarGrid" MinHeight="28" Padding="0,2,0,2"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" MinWidth="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="all-day" FontSize="10" VerticalAlignment="Center"
                       HorizontalAlignment="Right" Margin="0,0,8,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <!-- All-day event panels for each day column populated in code-behind -->
        </Grid>

        <!-- Row 2: Scrollable time grid -->
        <ScrollViewer Grid.Row="2" x:Name="TimeScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="TimeGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" MinWidth="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Hour labels, gridlines, and event canvases populated in code-behind -->
            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
