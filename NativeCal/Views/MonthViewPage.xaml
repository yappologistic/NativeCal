<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NativeCal.Views.MonthViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NativeCal.Views"
    xmlns:helpers="using:NativeCal.Helpers"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <helpers:ColorHexToBrushConverter x:Key="ColorHexToBrushConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid x:Name="LayoutRoot" RowDefinitions="Auto,*" Padding="4,0,4,4" SizeChanged="LayoutRoot_SizeChanged">

        <!-- Row 0: Day-of-week headers (populated dynamically based on first-day-of-week setting) -->
        <Grid x:Name="DayHeadersGrid" Grid.Row="0" Padding="0,8,0,8" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DayHeader0" Grid.Column="0" Text="Sun" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader1" Grid.Column="1" Text="Mon" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader2" Grid.Column="2" Text="Tue" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader3" Grid.Column="3" Text="Wed" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader4" Grid.Column="4" Text="Thu" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader5" Grid.Column="5" Text="Fri" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="DayHeader6" Grid.Column="6" Text="Sat" HorizontalAlignment="Center"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Row 1: 6x7 calendar grid, cells populated in code-behind -->
        <Grid Grid.Row="1" x:Name="CalendarGrid" ColumnSpacing="2" RowSpacing="2" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 42 cells created in code-behind -->
        </Grid>

    </Grid>
</Page>
