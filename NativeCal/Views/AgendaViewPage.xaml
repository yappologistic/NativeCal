<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NativeCal.Views.AgendaViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:NativeCal.Helpers"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <helpers:ColorHexToBrushConverter x:Key="ColorHexToBrushConverter"/>
    </Page.Resources>

    <Grid RowDefinitions="*">
        <ScrollViewer x:Name="AgendaScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="AgendaPanel" Padding="16,8" Spacing="4">
                <!-- Populated in code-behind with date groups and event cards -->
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE787;" FontSize="48"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="No upcoming events"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <Button Content="Create an event"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    Click="CreateEvent_Click"/>
        </StackPanel>

        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingRing" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Page>
