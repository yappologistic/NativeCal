<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NativeCal.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NativeCal.Views"
    Background="Transparent"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="24,16,24,16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="800" HorizontalAlignment="Left" Spacing="4">

            <!-- Appearance section -->
            <TextBlock Text="Appearance"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,8"/>

            <!-- Theme setting -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Text="App theme"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Select which app theme to display"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- NOTE: Do NOT set SelectedIndex in XAML — it triggers SelectionChanged
                         before LoadSettingsAsync reads the saved value, which would
                         overwrite the user's persisted theme choice. -->
                    <ComboBox x:Name="ThemeComboBox" Grid.Column="1"
                              MinWidth="140" MaxWidth="200"
                              VerticalAlignment="Center"
                              SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="System default"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- First day of week -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Text="First day of week"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Choose which day starts the week"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <ComboBox x:Name="FirstDayComboBox" Grid.Column="1"
                              MinWidth="140" MaxWidth="200"
                              VerticalAlignment="Center"
                              SelectionChanged="FirstDayComboBox_SelectionChanged">
                        <ComboBoxItem Content="Sunday"/>
                        <ComboBoxItem Content="Monday"/>
                        <ComboBoxItem Content="Saturday"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Default reminder -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Text="Default reminder"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Default reminder time for new events"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <ComboBox x:Name="ReminderComboBox" Grid.Column="1"
                              MinWidth="140" MaxWidth="200"
                              VerticalAlignment="Center"
                              SelectionChanged="ReminderComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" Tag="0"/>
                        <ComboBoxItem Content="5 minutes" Tag="5"/>
                        <ComboBoxItem Content="10 minutes" Tag="10"/>
                        <ComboBoxItem Content="15 minutes" Tag="15"/>
                        <ComboBoxItem Content="30 minutes" Tag="30"/>
                        <ComboBoxItem Content="1 hour" Tag="60"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Calendars section -->
            <TextBlock Text="Calendars"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,24,0,8"/>

            <!-- Calendar list populated in code-behind -->
            <StackPanel x:Name="CalendarSettingsPanel" Spacing="2"/>

            <Button Click="AddCalendar_Click"
                    Margin="0,8,0,0"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="Add calendar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- About section -->
            <TextBlock Text="About"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,24,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="NativeCal"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="A native Windows calendar application"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="VersionText" Text="Version 1.0.0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Bottom padding -->
            <Border Height="24"/>

        </StackPanel>
    </ScrollViewer>
</Page>
