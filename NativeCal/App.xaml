<Application
    x:Class="NativeCal.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Explicit ThemeDictionaries for brushes used in code-behind.
                The XAML runtime resolves {ThemeResource} automatically, but C# code
                using Application.Current.Resources["key"] resolves against the SYSTEM
                theme, not the app's RequestedTheme. Defining these here lets our
                ThemeResourceHelper find them in the app-level ThemeDictionaries.
            -->
            <ResourceDictionary.ThemeDictionaries>

                <!-- Light theme -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush"         Color="#E4000000" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush"       Color="#9E000000" />
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush"        Color="#5C000000" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#B3FFFFFF" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#80F6F6F6" />
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"       Color="#0F000000" />
                    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"    Color="#14000000" />
                </ResourceDictionary>

                <!-- Dark theme ("Default" key = dark in WinUI 3) -->
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush"         Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush"       Color="#C8FFFFFF" />
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush"        Color="#5DFFFFFF" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#0DFFFFFF" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#08FFFFFF" />
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"       Color="#19000000" />
                    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"    Color="#15FFFFFF" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
